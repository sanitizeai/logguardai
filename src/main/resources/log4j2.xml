<?xml version="1.0" encoding="UTF-8"?>
<Configuration  status="warn">
    <Properties>
        <Property name="log.dir">logs</Property>
        <Property name="log.pattern">%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n</Property>
    </Properties>

    <Appenders>
        <!-- Console Appender with LogGuardLayout -->
        <Console name="ConsoleAppender" target="SYSTEM_OUT">
            <LogGuardLayout
                charset="UTF-8"
                aiEnabled="false"
                aiThreshold="5"
                aiTimeoutMs="150"
                samplingRate="0.05"
                safeKeyPatterns=".*correlation.*,x-.*-id,.*trace.*,.*span.*"/>
        </Console>

        <!-- File Appender with LogGuardLayout -->
        <RollingFile name="FileAppender"
                     fileName="${log.dir}/application.log"
                     filePattern="${log.dir}/application-%d{yyyy-MM-dd}-%i.log"
                     createOnDemand="true">
            <LogGuardLayout
                charset="UTF-8"
                aiEnabled="false"
                aiThreshold="5"
                aiTimeoutMs="150"
                samplingRate="0.05"
                safeKeyPatterns=".*correlation.*,x-.*-id,.*trace.*,.*span.*"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="100MB"/>
            </Policies>
            <DefaultRolloverStrategy max="7"/>
        </RollingFile>

        <!-- Debug File (no sanitization for debugging) -->
        <RollingFile name="DebugAppender"
                     fileName="${log.dir}/debug.log"
                     filePattern="${log.dir}/debug-%d{yyyy-MM-dd}-%i.log">
            <PatternLayout pattern="%d{ISO8601} [%t] %-5level %logger{36} - %msg%n"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
            </Policies>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- Application loggers -->
        <Logger name="com.logguardai" level="info" additivity="false">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Logger>

        <!-- Debug logger -->
        <Logger name="com.logguardai.debug" level="debug" additivity="false">
            <AppenderRef ref="DebugAppender"/>
        </Logger>

        <!-- Root logger -->
        <Root level="info">
            <AppenderRef ref="ConsoleAppender"/>
            <AppenderRef ref="FileAppender"/>
        </Root>
    </Loggers>
</Configuration>
